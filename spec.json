{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://manim-widget/schema/v1",
  "title": "ManimWidgetScene",
  "description": "Complete serialized Manim scene for client-side playback.",
  "type": "object",
  "required": ["version", "fps", "sections"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "fps": {
      "type": "integer",
      "minimum": 1,
      "description": "Dry-run frame rate used for 'data' commands."
    },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/definitions/Section" }
    }
  },

  "definitions": {
    "Section": {
      "type": "object",
      "required": ["name", "snapshot", "states", "construct"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "unsupported": {
          "type": "boolean",
          "description": "If true, this section cannot be played back. JS must show a warning."
        },
        "unsupported_reason": {
          "type": "string",
          "description": "Human-readable explanation of why the section is unsupported."
        },
        "snapshot": {
          "oneOf": [{ "$ref": "#/definitions/Snapshot" }, { "type": "null" }],
          "description": "Full scene state at section entry. Null only when unsupported=true."
        },
        "states": {
          "type": "array",
          "description": "Section-local state bank. Integer refs (state_ref) index into this array.",
          "items": { "$ref": "#/definitions/MobjectState" }
        },
        "construct": {
          "type": "array",
          "items": { "$ref": "#/definitions/Command" },
          "description": "Ordered list of commands to execute. Empty when unsupported=true."
        }
      }
    },

    "Snapshot": {
      "type": "object",
      "description": "Flat map of mob_id -> SnapshotMobjectState. Fully self-contained.",
      "additionalProperties": { "$ref": "#/definitions/SnapshotMobjectState" }
    },

    "SnapshotMobjectState": {
      "description": "State variants valid inside section snapshots. Snapshot is self-contained, so group children reference snapshot mob_ids.",
      "oneOf": [
        { "$ref": "#/definitions/VMobjectState" },
        { "$ref": "#/definitions/TextState" },
        { "$ref": "#/definitions/MathTexState" },
        { "$ref": "#/definitions/VGroupState" },
        { "$ref": "#/definitions/ValueTrackerState" }
      ]
    },

    "MobjectState": {
      "description": "State variants valid inside section.states. This state bank is referenced by integer state_ref indices.",
      "oneOf": [
        { "$ref": "#/definitions/VMobjectState" },
        { "$ref": "#/definitions/TextState" },
        { "$ref": "#/definitions/MathTexState" },
        { "$ref": "#/definitions/StateGroupState" },
        { "$ref": "#/definitions/ValueTrackerState" }
      ]
    },

    "VMobjectState": {
      "type": "object",
      "required": ["kind", "points", "opacity"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "Circle",
            "Square",
            "Rectangle",
            "RoundedRectangle",
            "Triangle",
            "Polygon",
            "RegularPolygon",
            "Hexagon",
            "Pentagon",
            "Polygram",
            "ArcPolygon",
            "Line",
            "DashedLine",
            "CubicBezier",
            "Arrow",
            "DoubleArrow",
            "Vector",
            "CurvedArrow",
            "CurvedDoubleArrow",
            "Arc",
            "ArcBetweenPoints",
            "Ellipse",
            "Annulus",
            "AnnularSector",
            "Sector",
            "TangentialArc",
            "Dot",
            "SmallDot",
            "LargeDot",
            "BackgroundRectangle",
            "SurroundingRectangle",
            "Underline",
            "Cross",
            "Angle",
            "RightAngle",
            "Star",
            "Brace",
            "BraceBetweenPoints",
            "ArcBrace",
            "SVGMobject",
            "VMobjectFromSVGPath",
            "VMobject"
          ]
        },
        "points": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "description": "Bezier control points. Format: [p0, h0_a, h0_b, p1, h1_a, h1_b, p2, ...] where pi is a point and hi_a, hi_b are handles. Must have 3n+1 points (starting point + n cubic Bezier segments). Mobjects with multiple disconnected subpaths are serialized as VGroup with each subpath as a child."
        },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "color": { "$ref": "#/definitions/Color" },
        "fill_color": { "$ref": "#/definitions/Color" },
        "fill_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "stroke_color": { "$ref": "#/definitions/Color" },
        "stroke_width": { "type": "number", "minimum": 0 },
        "stroke_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "z_index": { "type": "number" }
      }
    },

    "TextState": {
      "type": "object",
      "required": ["kind", "text", "opacity"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["Text", "Paragraph", "MarkupText"]
        },
        "text": { "type": "string" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "color": { "$ref": "#/definitions/Color" },
        "font_size": { "type": "number" },
        "z_index": { "type": "number" }
      }
    },

    "MathTexState": {
      "type": "object",
      "required": ["kind", "latex", "opacity"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["MathTex", "Tex"] },
        "latex": {
          "type": "string",
          "description": "Raw LaTeX string. Rendered in JS via KaTeX."
        },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "color": { "$ref": "#/definitions/Color" },
        "font_size": { "type": "number" },
        "z_index": { "type": "number" }
      }
    },

    "VGroupState": {
      "type": "object",
      "required": ["kind", "children", "opacity"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "VGroup" },
        "children": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of child snapshot mob_ids. Snapshot-only representation to keep snapshot self-contained."
        },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "z_index": { "type": "number" }
      }
    },

    "StateGroupState": {
      "type": "object",
      "required": ["kind", "state_children", "opacity"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "StateGroup" },
        "state_children": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "description": "Ordered list of child state references. State-bank-only representation; each entry indexes into section.states."
        },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "z_index": { "type": "number" }
      }
    },

    "ValueTrackerState": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "ValueTracker" },
        "value": {
          "type": "number",
          "description": "Current tracked value. Not rendered; used by updater-driven animations."
        }
      }
    },

    "Command": {
      "oneOf": [
        { "$ref": "#/definitions/AddCommand" },
        { "$ref": "#/definitions/RemoveCommand" },
        { "$ref": "#/definitions/RebindCommand" },
        { "$ref": "#/definitions/AnimateCommand" },
        { "$ref": "#/definitions/DataCommand" }
      ]
    },

    "AddCommand": {
      "type": "object",
      "description": "Register or update a mobject in the JS scene graph by binding id to a section-local state_ref.",
      "required": ["cmd", "id", "state_ref"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "add" },
        "id": { "type": "string" },
        "state_ref": {
          "type": "integer",
          "minimum": 0,
          "description": "Index into section.states."
        }
      }
    },

    "RemoveCommand": {
      "type": "object",
      "description": "Remove a mobject from the JS scene graph and free it from the registry. Always emitted after FadeOut/Uncreate/Unwrite animations and after ReplacementTransform (removes source).",
      "required": ["cmd", "id"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "remove" },
        "id": { "type": "string" }
      }
    },

    "RebindCommand": {
      "type": "object",
      "description": "Rebind an existing runtime mobject identity from one id to another.",
      "required": ["cmd", "source_id", "target_id"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "rebind" },
        "source_id": {
          "type": "string",
          "description": "Current registry id for the runtime object."
        },
        "target_id": {
          "type": "string",
          "description": "New registry id for the same runtime object."
        }
      }
    },

    "AnimateCommand": {
      "type": "object",
      "description": "One scene.play() call. All animations run in parallel unless composition types dictate otherwise.",
      "required": ["cmd", "duration", "animations"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "animate" },
        "duration": { "type": "number", "minimum": 0 },
        "animations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/AnimationDescriptor" }
        }
      }
    },

    "DataCommand": {
      "type": "object",
      "description": "One scene.play() call that involves updaters. Frames reference section.states entries.",
      "required": ["cmd", "duration", "frames"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "data" },
        "duration": { "type": "number", "minimum": 0 },
        "frames": {
          "type": "array",
          "description": "Length = ceil(duration * fps). Each entry maps mob_id to frame state references.",
          "items": {
            "type": "object",
            "description": "Map of mob_id -> frame state entry.",
            "additionalProperties": { "$ref": "#/definitions/FrameState" }
          }
        }
      }
    },

    "FrameState": {
      "type": "object",
      "description": "Per-frame update by reference into section.states.",
      "required": ["state_ref"],
      "additionalProperties": false,
      "properties": {
        "state_ref": {
          "type": "integer",
          "minimum": 0,
          "description": "Index into section.states for this frame's full state."
        }
      }
    },

    "AnimationDescriptor": {
      "oneOf": [
        { "$ref": "#/definitions/SimpleAnimation" },
        { "$ref": "#/definitions/PairAnimation" },
        { "$ref": "#/definitions/GroupAnimation" },
        { "$ref": "#/definitions/TransformAnimation" }
      ]
    },

    "SimpleAnimation": {
      "type": "object",
      "required": ["type", "kind", "id"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "simple" },
        "kind": {
          "type": "string",
          "enum": [
            "Create",
            "Uncreate",
            "Write",
            "Unwrite",
            "FadeIn",
            "FadeOut",
            "Shift",
            "Rotate",
            "ScaleInPlace",
            "ShrinkToCenter",
            "FadeToColor",
            "GrowFromCenter",
            "GrowFromEdge",
            "GrowFromPoint",
            "GrowArrow",
            "SpinInFromNothing",
            "MoveAlongPath",
            "Indicate",
            "Flash",
            "Circumscribe",
            "Wiggle",
            "ShowPassingFlash",
            "ApplyWave",
            "FocusOn",
            "Pulse",
            "ShowCreationThenDestruction",
            "WiggleOutThenIn",
            "Blink",
            "ChangingDecimal",
            "ChangeDecimalToValue",
            "Rotating",
            "Broadcast",
            "Wait"
          ]
        },
        "id": {
          "type": "string",
          "description": "mob_id of the target mobject."
        },
        "rate_func": { "$ref": "#/definitions/RateFunc" },
        "params": { "$ref": "#/definitions/SimpleAnimationParams" }
      }
    },

    "PairAnimation": {
      "type": "object",
      "required": ["type", "kind", "source_id", "target_id"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "pair" },
        "kind": {
          "type": "string",
          "enum": [
            "Swap"
          ]
        },
        "source_id": {
          "type": "string",
          "description": "mob_id of the source mobject."
        },
        "target_id": {
          "type": "string",
          "description": "mob_id of the target mobject."
        },
        "rate_func": { "$ref": "#/definitions/RateFunc" },
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        }
      }
    },

    "GroupAnimation": {
      "type": "object",
      "required": ["type", "kind", "ids"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "group" },
        "kind": {
          "type": "string",
          "enum": [
            "CyclicReplace"
          ]
        },
        "ids": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string" },
          "description": "Ordered mob_ids participating in the group animation."
        },
        "rate_func": { "$ref": "#/definitions/RateFunc" },
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        }
      }
    },

    "TransformAnimation": {
      "type": "object",
      "required": ["type", "kind", "id", "state_ref"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "transform" },
        "kind": {
          "type": "string",
          "enum": [
            "Transform"
          ]
        },
        "id": {
          "type": "string",
          "description": "mob_id of the transformed mobject."
        },
        "state_ref": {
          "type": "integer",
          "minimum": 0,
          "description": "Index into section.states for destination state."
        },
        "rate_func": { "$ref": "#/definitions/RateFunc" },
        "params": { "$ref": "#/definitions/TransformAnimationParams" }
      }
    },

    "SimpleAnimationParams": {
      "type": "object",
      "description": "Animation-specific parameters for simple animations.",
      "additionalProperties": false,
      "properties": {
        "vector": {
          "$ref": "#/definitions/Vec3",
          "description": "Shift: displacement vector."
        },
        "angle": {
          "type": "number",
          "description": "Rotate: angle in radians."
        },
        "axis": {
          "$ref": "#/definitions/Vec3",
          "description": "Rotate: rotation axis. Defaults to [0,0,1]."
        },
        "scale_factor": {
          "type": "number",
          "description": "ScaleInPlace."
        },
        "color": {
          "$ref": "#/definitions/Color",
          "description": "FadeToColor: target color."
        },
        "point": {
          "$ref": "#/definitions/Vec3",
          "description": "GrowFromPoint: origin point."
        },
        "path_id": {
          "type": "string",
          "description": "MoveAlongPath: mob_id of the path VMobject."
        },
        "value": {
          "type": "number",
          "description": "ChangeDecimalToValue: target value."
        }
      }
    },

    "TransformAnimationParams": {
      "type": "object",
      "description": "Animation-specific parameters for transform animations.",
      "additionalProperties": false,
      "properties": {
        "path_arc": {
          "type": "number",
          "description": "Optional transform path arc in radians."
        },
        "path_arc_axis": {
          "$ref": "#/definitions/Vec3",
          "description": "Optional transform path arc axis."
        }
      }
    },

    "RateFunc": {
      "type": "string",
      "enum": [
        "linear",
        "smooth",
        "rush_into",
        "rush_from",
        "slow_into",
        "there_and_back",
        "wiggle",
        "ease_in_sine",
        "ease_out_sine",
        "ease_in_out_sine",
        "ease_in_quad",
        "ease_out_quad",
        "ease_in_out_quad",
        "ease_in_cubic",
        "ease_out_cubic",
        "ease_in_out_cubic",
        "ease_in_quart",
        "ease_out_quart",
        "ease_in_out_quart",
        "ease_in_quint",
        "ease_out_quint",
        "ease_in_out_quint",
        "ease_in_expo",
        "ease_out_expo",
        "ease_in_out_expo",
        "ease_in_circ",
        "ease_out_circ",
        "ease_in_out_circ",
        "ease_in_back",
        "ease_out_back",
        "ease_in_out_back",
        "ease_in_elastic",
        "ease_out_elastic",
        "ease_in_out_elastic",
        "ease_in_bounce",
        "ease_out_bounce",
        "ease_in_out_bounce"
      ]
    },

    "Vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "[x, y, z]"
    },

    "Color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "Hex color string, e.g. '#ff0000'."
    }
  }
}
