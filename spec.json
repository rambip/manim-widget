{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://manim-widget/schema/v2",
  "title": "ManimWidgetScene",
  "description": "Complete serialized Manim scene for client-side playback.",
  "type": "object",
  "required": ["version", "sections"],
  "additionalProperties": false,
  "properties": {
    "fps": {
      "type": "integer",
      "minimum": 0
    },
    "version": {
      "type": "integer",
      "const": 2
    },
    "frame_width": {
      "type": "integer"
    },
    "frame_heighheight": {
      "type": "integer"
    },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/definitions/Section" }
    }
  },

  "definitions": {
    "Section": {
      "type": "object",
      "required": ["name", "snapshot", "states", "construct"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "background_color": {
          "$ref": "#/definitions/Color"
        },
        "unsupported": {
          "type": "boolean",
          "description": "If true, this section cannot be played back. JS must show a warning."
        },
        "unsupported_reason": {
          "type": "string",
          "description": "Human-readable explanation of why the section is unsupported."
        },
        "snapshot": {
          "oneOf": [{ "$ref": "#/definitions/Snapshot" }, { "type": "null" }],
          "description": "Full scene state at section entry. Null only when unsupported=true. Maps mob_id to state_ref index into section.states."
        },
        "states": {
          "type": "array",
          "description": "List of all serialized Geometrical data that will be used in this section (excluding updaters). Other commands and animations acces it using integer indices.",
          "items": { "$ref": "#/definitions/MobjectState" }
        },
        "construct": {
          "type": "array",
          "items": { "$ref": "#/definitions/Command" },
          "description": "Ordered list of commands to execute. Empty when unsupported=true."
        },
        "camera": {
          "$ref": "#/definitions/CameraState",
          "description": "Camera state at section entry (phi, theta, distance, look_at). Used for section jumps without replay."
        }
      }
    },

    "Snapshot": {
      "type": "object",
      "description": "Scene state at the start of this section. It is a map of object_id -> index in section.states. Note that for groups, VGroup children are NOT included - the player must restore the children from VGroupState.children.",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },

    "MobjectState": {
      "description": "State variant holding geometrical or textual data. Nature of data is determined by the 'kind' field: either 'VMobject', 'VGroup', 'MathTexSource'",
      "oneOf": [
        { "$ref": "#/definitions/VMobjectState" },
        { "$ref": "#/definitions/VGroupState" },
        { "$ref": "#/definitions/MathTexSourceState" },
        { "$ref": "#/definitions/ImageMobjectState" },
        { "$ref": "#/definitions/ValueTrackerState" }
      ]
    },

    "VMobjectState": {
      "type": "object",
      "required": ["kind", "points"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "VMobject",
          "description": "Generic VMobject state with bezier points."
        },
        "points": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "description": "Bezier control points. Format: [p0, h0_a, h0_b, p1, h1_a, h1_b, p2, ...] where pi is a point and hi_a, hi_b are handles. Must have 3n+1 points (starting point + n cubic Bezier segments). Mobjects with multiple disconnected subpaths are serialized as VGroup with each subpath as a child."
        },
        "fill_color": { "$ref": "#/definitions/Color" },
        "fill_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "stroke_color": { "$ref": "#/definitions/Color" },
        "stroke_width": { "type": "number", "minimum": 0 },
        "stroke_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "z_index": { "type": "number" },
        "text": {
          "type": "string",
          "description": "Text content for Text/MarkupText mobjects."
        },
        "font_size": {
          "type": "number",
          "description": "Font size for Text/MarkupText mobjects."
        }
      }
    },

    "VGroupState": {
      "type": "object",
      "required": ["kind", "children"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "VGroup",
          "description": "Group of child mobjects."
        },
        "children": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "description": "Ordered list of child state_refs. Resolved through section.states to create child mobjects. VGroup children are NOT in the snapshot - only the VGroup root is."
        },
        "z_index": { "type": "number" }
      }
    },

    "MathTexSourceState": {
      "type": "object",
      "required": ["kind", "latex", "points"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "MathTexSource",
          "description": "LaTeX math expression rendered client-side."
        },
        "latex": {
          "type": "string",
          "description": "Raw LaTeX string. Rendered client-side."
        },
        "points": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "minItems": 4,
          "maxItems": 4,
          "description": "Local coordinate system [origin, right_point, up_point, top_right] for transform support. The unit square [ORIGIN, RIGHT, UP, RIGHT+UP] corresponds to a centered LaTeX glyph at unit scale. JS: 1) center the rendered glyph, 2) apply matrix derived from (right-origin, up-origin), 3) shift by origin. Result: object center at origin."
        },
        "stroke_opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "color": { "$ref": "#/definitions/Color" },
        "font_size": { "type": "number" },
        "z_index": { "type": "number" }
      }
    },

    "ImageMobjectState": {
      "type": "object",
      "required": ["kind", "source", "points"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "ImageMobject"
        },
        "source": {
          "type": "string",
          "description": "Image source URL. Typically a data URI (data:image/png;base64,...)."
        },
        "points": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "description": "Image corners in scene coordinates ordered as [UL, UR, DL, DR]."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "z_index": { "type": "number" }
      }
    },

    "ValueTrackerState": {
      "type": "object",
      "required": ["value", "kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "ValueTracker"
        },
        "value": {
          "type": "number",
          "description": "Current tracked value. Not rendered; used by updater-driven animations."
        }
      }
    },

    "Command": {
      "oneOf": [
        { "$ref": "#/definitions/AddCommand" },
        { "$ref": "#/definitions/RemoveCommand" },
        { "$ref": "#/definitions/RebindCommand" },
        { "$ref": "#/definitions/AnimateCommand" }
      ]
    },

    "AddCommand": {
      "type": "object",
      "description": "Register or update a mobject in the JS scene graph by binding id to a section-local state_ref.",
      "required": ["cmd", "id", "state_ref"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "add" },
        "id": { "type": "string" },
        "state_ref": {
          "type": "integer",
          "minimum": 0,
          "description": "Index into section.states."
        },
        "hidden": {
          "type": "boolean",
          "description": "If true, mobject is staged but not added to scene. Intro animations (Create, FadeIn, etc.) pull from staging bucket and add to scene when they begin."
        }
      }
    },

    "RemoveCommand": {
      "type": "object",
      "description": "Remove a mobject from the JS scene graph and free it from the registry. Always emitted after FadeOut/Uncreate/Unwrite animations and after ReplacementTransform (removes source).",
      "required": ["cmd", "id"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "remove" },
        "id": { "type": "string" }
      }
    },

    "RebindCommand": {
      "type": "object",
      "description": "Rebind an existing runtime mobject identity from one id to another.",
      "required": ["cmd", "source_id", "target_id"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "rebind" },
        "source_id": {
          "type": "string",
          "description": "Current registry id for the runtime object."
        },
        "target_id": {
          "type": "string",
          "description": "New registry id for the same runtime object."
        }
      }
    },

    "AnimateCommand": {
      "type": "object",
      "description": "One scene.play() call. All animations run in parallel by default",
      "required": ["cmd", "duration", "animations"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "animate" },
        "duration": { "type": "number", "minimum": 0 },
        "animations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/AnimationDescriptor" }
        },
        "updaters": {
          "type": "object",
          "description": "Add 'updaters' (animations running between each frame) for objects from their ids.",
          "additionalProperties": {
            "$ref": "#/definitions/UpdaterDescriptor"
          }
        },
        "camera_updates": {
          "$ref": "#/definitions/CameraUpdaterData",
          "description": "Per-frame camera state. Captured when camera moves via move_camera() or camera updaters."
        }
      }
    },

    "UpdaterDescriptor": {
      "type": "object",
      "description": "For objects using updaters, snapshots of the object properties at every frame.",
      "required": ["cmd", "duration", "updates"],
      "additionalProperties": false,
      "properties": {
        "cmd": { "type": "string", "const": "updater" },
        "updates": {
          "description": "Data to update object properties (points, color, opacity ...) at each frame. Data for all properties must contain the same number of values (one per frame)",
          "additionalProperties": {
            "description": "The data for each frame. Use the 'scheme' field to specify how it is encoded.",
            "oneOf": [
              { "$ref": "#/definitions/RawUpdaterData" },
              { "$ref": "#/definitions/ZLibUpdaterData" },
              { "$ref": "#/definitions/DeltaPointUpdaterData" }
            ]
          }
        }
      }
    },

    "RawUpdaterData": {
      "description": "Properties passed as a json array (uncompressed)",
      "required": ["scheme", "value"],
      "properties": {
        "scheme": {
          "type": "string",
          "const": "raw"
        },
        "value": {
          "type": "array"
        }
      }
    },
    "ZLibUpdaterData": {
      "description": "String properties encoded as a new-line separated string, encoded with zlib",
      "required": ["scheme", "value"],
      "properties": {
        "scheme": {
          "type": "string",
          "const": "zlib"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "DeltaPointUpdaterData": {
      "description": "Encoding scheme for point arrays that vary across frames. Points are stored as three separate zlib-compressed base64 buffers, one per axis (x, y, z). Each buffer is a row-major float32 matrix of shape [F, W], where F is the number of frames and W is the length of the longest point array across all frames (the 'width' field). Each row corresponds to one frame; slots beyond the actual point count are set to NaN. Values are delta-encoded between frames: the stored value is the difference from the previous frame, or the absolute value if the previous frame was NaN.",
      "required": ["width", "scheme", "x", "y", "z"],
      "additionalProperties": false,
      "properties": {
        "scheme": {
          "type": "string",
          "const": "delta"
        },
        "width": {
          "type": "integer",
          "description": "Length of the longest point array across all frames."
        },
        "x": {
          "type": "string",
          "description": "base64(zlib(float32[F, W])) for the x axis."
        },
        "y": {
          "type": "string",
          "description": "base64(zlib(float32[F, W])) for the y axis."
        },
        "z": {
          "type": "string",
          "description": "base64(zlib(float32[F, W])) for the z axis."
        }
      }
    },

    "AnimationDescriptor": {
      "oneOf": [
        { "$ref": "#/definitions/SimpleAnimation" },
        { "$ref": "#/definitions/WaitAnimation" },
        { "$ref": "#/definitions/GroupAnimation" },
        { "$ref": "#/definitions/TransformAnimation" }
      ]
    },

    "WaitAnimation": {
      "type": "object",
      "description": "Wait animation - pauses without operating on any mobject.",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "Wait" },
        "rate_func": { "$ref": "#/definitions/RateFunc" }
      }
    },

    "SimpleAnimation": {
      "type": "object",
      "required": ["kind", "id"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "anyOf": [
            { "type": "string" },
            {
              "enum": [
                "Create",
                "Uncreate",
                "Write",
                "Unwrite",
                "FadeIn",
                "FadeOut",
                "Rotate",
                "ScaleInPlace",
                "ShrinkToCenter",
                "GrowFromCenter",
                "GrowFromEdge",
                "GrowArrow",
                "SpinInFromNothing",
                "MoveAlongPath",
                "Indicate",
                "Flash",
                "Circumscribe",
                "Wiggle",
                "ShowPassingFlash",
                "ApplyWave",
                "FocusOn",
                "Pulse",
                "ShowCreationThenDestruction",
                "WiggleOutThenIn",
                "Blink",
                "Rotating",
                "Broadcast"
              ]
            }
          ]
        },

        "id": {
          "type": "string",
          "description": "mob_id of the target mobject."
        },
        "rate_func": { "$ref": "#/definitions/RateFunc" },
        "params": { "$ref": "#/definitions/SimpleAnimationParams" }
      }
    },

    "GroupAnimation": {
      "type": "object",
      "required": ["kind", "ids"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["Swap", "CyclicReplace"]
        },
        "ids": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string" },
          "description": "Ordered mob_ids participating in the group animation. For Swap, must be exactly 2. For CyclicReplace, each mobject moves to the next position in order."
        },
        "rate_func": { "$ref": "#/definitions/RateFunc" },
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path_arc": {
              "type": "number",
              "description": "Arc angle for the movement path in radians. Default is PI/2."
            }
          }
        }
      }
    },

    "TransformAnimation": {
      "type": "object",
      "required": ["kind", "id", "state_ref"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["Transform", "MoveToTarget"]
        },
        "id": {
          "type": "string",
          "description": "mob_id of the transformed mobject."
        },
        "state_ref": {
          "type": "integer",
          "minimum": 0,
          "description": "Index into section.states for destination state."
        },
        "rate_func": { "$ref": "#/definitions/RateFunc" },
        "params": { "$ref": "#/definitions/TransformAnimationParams" }
      }
    },

    "SimpleAnimationParams": {
      "type": "object",
      "description": "Animation-specific parameters for simple animations.",
      "additionalProperties": false,
      "properties": {
        "angle": {
          "type": "number",
          "description": "Rotate: angle in radians."
        },
        "axis": {
          "$ref": "#/definitions/Vec3",
          "description": "Rotate: rotation axis. Defaults to [0,0,1]."
        },
        "scale_factor": {
          "type": "number",
          "description": "ScaleInPlace."
        },
        "about_point": {
          "$ref": "#/definitions/Vec3",
          "description": "Rotation/scale center point."
        },
        "path_id": {
          "type": "string",
          "description": "MoveAlongPath: mob_id of the path VMobject."
        }
      }
    },

    "TransformAnimationParams": {
      "type": "object",
      "description": "Animation-specific parameters for transform animations.",
      "additionalProperties": false,
      "properties": {
        "path_arc": {
          "type": "number",
          "description": "Optional transform path arc in radians."
        },
        "path_arc_axis": {
          "$ref": "#/definitions/Vec3",
          "description": "Optional transform path arc axis."
        }
      }
    },

    "RateFunc": {
      "type": "string",
      "enum": [
        "linear",
        "smooth",
        "rush_into",
        "rush_from",
        "slow_into",
        "there_and_back",
        "wiggle",
        "ease_in_sine",
        "ease_out_sine",
        "ease_in_out_sine",
        "ease_in_quad",
        "ease_out_quad",
        "ease_in_out_quad",
        "ease_in_cubic",
        "ease_out_cubic",
        "ease_in_out_cubic",
        "ease_in_quart",
        "ease_out_quart",
        "ease_in_out_quart",
        "ease_in_quint",
        "ease_out_quint",
        "ease_in_out_quint",
        "ease_in_expo",
        "ease_out_expo",
        "ease_in_out_expo",
        "ease_in_circ",
        "ease_out_circ",
        "ease_in_out_circ",
        "ease_in_back",
        "ease_out_back",
        "ease_in_out_back",
        "ease_in_elastic",
        "ease_out_elastic",
        "ease_in_out_elastic",
        "ease_in_bounce",
        "ease_out_bounce",
        "ease_in_out_bounce"
      ]
    },

    "Vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "[x, y, z]"
    },

    "CameraState": {
      "type": "object",
      "description": "3D camera spherical coordinates at section entry.",
      "required": ["phi", "theta", "distance"],
      "properties": {
        "phi": {
          "type": "number",
          "description": "Polar angle from Y axis (0 = top, PI = bottom)."
        },
        "theta": {
          "type": "number",
          "description": "Azimuthal angle in XZ plane."
        },
        "distance": {
          "type": "number",
          "description": "Distance from look-at point."
        },
        "fov": {
          "type": "number",
          "description": "Field of view in degrees. Defaults to 77.32 (matches Manim: frame_height=8 at distance=5)."
        },
        "look_at": {
          "$ref": "#/definitions/Vec3",
          "description": "Camera look-at target point. Defaults to [0, 0, 0]."
        }
      }
    },

    "CameraUpdaterData": {
      "type": "array",
      "description": "Per-frame camera state. Array of camera states, one per frame. Deduplicated - only includes frames where camera changed.",
      "items": {
        "$ref": "#/definitions/CameraFrame"
      }
    },

    "CameraFrame": {
      "type": "object",
      "description": "Single frame of camera state.",
      "properties": {
        "phi": { "type": "number" },
        "theta": { "type": "number" },
        "distance": { "type": "number" },
        "fov": { "type": "number" },
        "look_at": { "$ref": "#/definitions/Vec3" }
      }
    },

    "Color": {
      "oneOf": [
        {
          "description": "Transparent / no color.",
          "type": "null"
        },
        {
          "description": "Solid, alpha=1.",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        {
          "description": "Per-point gradient. Each entry is a hex string (alpha=1) or [hex, alpha] tuple.",
          "type": "array",
          "minItems": 2,
          "items": {
            "oneOf": [
              { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
              {
                "type": "array",
                "items": false,
                "prefixItems": [
                  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
                  { "type": "number", "minimum": 0, "maximum": 1 }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
